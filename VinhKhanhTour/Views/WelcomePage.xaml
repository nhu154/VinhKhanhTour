<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="VinhKhanhTour.Views.WelcomePage"
             NavigationPage.HasNavigationBar="False"
             BackgroundColor="#F0F6FF">
    <ScrollView>
        <VerticalStackLayout Spacing="0">

            <!-- ══ HERO SECTION ══ -->
            <Grid HeightRequest="440">
                <BoxView>
                    <BoxView.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                            <GradientStop Color="#1565C0" Offset="0"/>
                            <GradientStop Color="#1976D2" Offset="0.4"/>
                            <GradientStop Color="#42A5F5" Offset="0.85"/>
                            <GradientStop Color="#64B5F6" Offset="1"/>
                        </LinearGradientBrush>
                    </BoxView.Background>
                </BoxView>
                <Ellipse Fill="#42A5F5" Opacity="0.12"
                         WidthRequest="360" HeightRequest="360"
                         HorizontalOptions="End" VerticalOptions="Start"
                         Margin="0,-120,-100,0"/>
                <Ellipse Fill="#90CAF9" Opacity="0.09"
                         WidthRequest="200" HeightRequest="200"
                         HorizontalOptions="End" VerticalOptions="Start"
                         Margin="0,-20,-30,0"/>
                <Ellipse Fill="#1565C0" Opacity="0.14"
                         WidthRequest="300" HeightRequest="300"
                         HorizontalOptions="Start" VerticalOptions="End"
                         Margin="-100,0,0,-80"/>
                <BoxView HeightRequest="1" BackgroundColor="#64B5F6" Opacity="0.20"
                         VerticalOptions="End" Margin="24,0,24,90"/>
                <Grid Padding="24,55,24,28">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Top bar -->
                    <Grid Grid.Row="0" ColumnDefinitions="*,Auto" Margin="0,0,0,20">
                        <Border BackgroundColor="#301565C0" StrokeShape="RoundRectangle 8"
                                Stroke="#6042A5F5" Padding="10,5" HorizontalOptions="Start">
                            <HorizontalStackLayout Spacing="5">
                                <Label Text="📍" FontSize="12"/>
                                <Label x:Name="LblLocation" Text="Quận 4 · TP.HCM" FontSize="11"
                                       TextColor="#BBDEFB" FontAttributes="Bold"/>
                            </HorizontalStackLayout>
                        </Border>
                        <Border Grid.Column="1" x:Name="LangBtn"
                                BackgroundColor="#15FFFFFF" StrokeShape="RoundRectangle 20"
                                Stroke="#30FFFFFF" Padding="12,7">
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Tapped="OnLangBtnClicked"/>
                            </Border.GestureRecognizers>
                            <HorizontalStackLayout Spacing="6">
                                <Label x:Name="LangFlag" Text="ðŸ‡»ðŸ‡³" FontSize="16"/>
                                <Label Text="▾" FontSize="11" TextColor="#88FFFFFF"
                                       VerticalOptions="Center"/>
                            </HorizontalStackLayout>
                        </Border>
                    </Grid>

                    <Border x:Name="LangDropdown" Grid.Row="0" Grid.RowSpan="3"
                            IsVisible="False" BackgroundColor="#FFFFFF"
                            StrokeShape="RoundRectangle 14" Stroke="#1565C0"
                            Padding="0" Margin="0,40,0,0"
                            HorizontalOptions="End" VerticalOptions="Start"
                            ZIndex="999">
                        <Border.Shadow>
                            <Shadow Brush="#1565C0" Opacity="0.4" Radius="20" Offset="0,8"/>
                        </Border.Shadow>
                        <VerticalStackLayout x:Name="LangDropdownList" Spacing="0"/>
                    </Border>

                    <!-- Tiêu đề -->
                    <VerticalStackLayout Grid.Row="1" Spacing="0" VerticalOptions="Center">
                        <Label Text="VĨNH KHÁNH" FontSize="44" FontAttributes="Bold"
                               TextColor="#FFFFFF" CharacterSpacing="3" LineHeight="1.1"/>
                        <HorizontalStackLayout Spacing="0" Margin="0,3,0,0">
                            <BoxView WidthRequest="36" HeightRequest="3"
                                     BackgroundColor="#42A5F5" VerticalOptions="Center"/>
                            <Label x:Name="LblMainSubtitle" Text="  CẨM NANG ẨM THỰC" FontSize="13" FontAttributes="Bold"
                                   TextColor="#64B5F6" CharacterSpacing="3" VerticalOptions="Center"/>
                        </HorizontalStackLayout>
                        <Label x:Name="LblWelcome"
                               Text="Khám phá phố ẩm thực nổi tiếng nhất Quận 4"
                               FontSize="14" TextColor="#99FFFFFF" LineHeight="1.5" Margin="0,13,0,0"/>
                        <HorizontalStackLayout Spacing="20" Margin="0,18,0,0">
                            <VerticalStackLayout Spacing="2">
                                <Label x:Name="LblStats1Value" Text="11" FontSize="24" FontAttributes="Bold" TextColor="#64B5F6"/>
                                <Label x:Name="LblStats1Text" Text="Quán ăn" FontSize="11" TextColor="#66FFFFFF"/>
                            </VerticalStackLayout>
                            <BoxView WidthRequest="1" BackgroundColor="#22FFFFFF" VerticalOptions="Fill"/>
                            <VerticalStackLayout Spacing="2">
                                <Label x:Name="LblStats2Value" Text="4" FontSize="24" FontAttributes="Bold" TextColor="#64B5F6"/>
                                <Label x:Name="LblStats2Text" Text="Tour chủ đề" FontSize="11" TextColor="#66FFFFFF"/>
                            </VerticalStackLayout>
                            <BoxView WidthRequest="1" BackgroundColor="#22FFFFFF" VerticalOptions="Fill"/>
                            <VerticalStackLayout Spacing="2">
                                <Label x:Name="LblStats3Value" Text="4.5★" FontSize="24" FontAttributes="Bold" TextColor="#64B5F6"/>
                                <Label x:Name="LblStats3Text" Text="Đánh giá" FontSize="11" TextColor="#66FFFFFF"/>
                            </VerticalStackLayout>
                        </HorizontalStackLayout>
                    </VerticalStackLayout>

                    <!-- CTA Button -->
                    <Border Grid.Row="2" StrokeShape="RoundRectangle 16"
                            Stroke="Transparent" Margin="0,22,0,0">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                <GradientStop Color="#1565C0" Offset="0"/>
                                <GradientStop Color="#42A5F5" Offset="1"/>
                            </LinearGradientBrush>
                        </Border.Background>
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnMapClicked"/>
                        </Border.GestureRecognizers>
                        <Border.Shadow>
                            <Shadow Brush="#1565C0" Opacity="0.55" Radius="18" Offset="0,7"/>
                        </Border.Shadow>
                        <Grid ColumnDefinitions="*,Auto" Padding="22,16">
                            <HorizontalStackLayout Spacing="8">
                                <Path Data="M3 11 L22 2 L13 21 L11 13 Z" Stroke="White" StrokeThickness="2" Fill="Transparent" WidthRequest="18" HeightRequest="18" VerticalOptions="Center"/>
                                <Label x:Name="LblCTA" Text="Bắt đầu khám phá" FontSize="16"
                                       FontAttributes="Bold" TextColor="White" VerticalOptions="Center"/>
                            </HorizontalStackLayout>
                            <Label Grid.Column="1" Text="→" FontSize="22"
                                   TextColor="White" VerticalOptions="Center"/>
                        </Grid>
                    </Border>
                </Grid>
            </Grid>

            <!-- ══ GIỌNG THUYẾT MINH ══ -->
            <VerticalStackLayout BackgroundColor="#FFFFFF" Padding="24,20" Spacing="14" Margin="0,2,0,0">
                <HorizontalStackLayout Spacing="10">
                    <Border BackgroundColor="#251565C0" StrokeShape="RoundRectangle 8"
                            Stroke="Transparent" Padding="8,6">
                        <Label Text="🎙️" FontSize="16"/>
                    </Border>
                    <VerticalStackLayout Spacing="1" VerticalOptions="Center">
                        <Label x:Name="LblNarration" Text="Giọng thuyết minh"
                               FontSize="16" FontAttributes="Bold" TextColor="#0D2137"/>
                        <Label x:Name="LblNarrationSub" Text="Chọn ngôn ngữ audio tour" FontSize="11" TextColor="#5A7A9A"/>
                    </VerticalStackLayout>
                </HorizontalStackLayout>
                <FlexLayout x:Name="LangBtnContainer"
                            Wrap="Wrap"
                            JustifyContent="SpaceEvenly"
                            AlignItems="Center"/>
            </VerticalStackLayout>

            <!-- ══ MINI MAP ══ -->
            <VerticalStackLayout Padding="24,20" Spacing="14" BackgroundColor="#F0F6FF" Margin="0,2,0,0">
                <HorizontalStackLayout Spacing="10">
                    <Border BackgroundColor="#251565C0" StrokeShape="RoundRectangle 8"
                            Stroke="Transparent" Padding="8,6">
                        <Label Text="🗺️" FontSize="16"/>
                    </Border>
                    <VerticalStackLayout Spacing="1" VerticalOptions="Center">
                        <Label x:Name="LblChoTour" Text="Khu vực Vĩnh Khánh"
                               FontSize="16" FontAttributes="Bold" TextColor="#0D2137"/>
                        <Label x:Name="LblChoTourSub" Text="Phố ẩm thực nổi tiếng Quận 4" FontSize="11" TextColor="#5A7A9A"/>
                    </VerticalStackLayout>
                </HorizontalStackLayout>
                <Border StrokeShape="RoundRectangle 18" Stroke="#CCE0FF"
                        HeightRequest="190" BackgroundColor="#FFFFFF">
                    <Border.Shadow>
                        <Shadow Brush="#1565C0" Opacity="0.25" Radius="14" Offset="0,5"/>
                    </Border.Shadow>
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnMapClicked"/>
                    </Border.GestureRecognizers>
                    <Grid>
                        <WebView x:Name="MiniMapWebView" HorizontalOptions="Fill" VerticalOptions="Fill"/>
                        <Grid BackgroundColor="Transparent">
                            <Grid.GestureRecognizers>
                                <TapGestureRecognizer Tapped="OnMapClicked"/>
                            </Grid.GestureRecognizers>
                        </Grid>
                        <Border BackgroundColor="#AA000000" StrokeShape="RoundRectangle 10"
                                Stroke="Transparent" Padding="12,7"
                                HorizontalOptions="Center" VerticalOptions="End" Margin="0,0,0,12">
                            <Label x:Name="LblTapHint" Text="ðŸ‘† Nhấn để xem bản đồ chi tiết"
                                   FontSize="12" TextColor="White" FontAttributes="Bold"/>
                        </Border>
                    </Grid>
                </Border>
            </VerticalStackLayout>

            <!-- ══ TOUR CARDS ══ -->
            <VerticalStackLayout Padding="20,20,20,36" Spacing="0" BackgroundColor="#F0F6FF" Margin="0,2,0,0">
                <HorizontalStackLayout Spacing="10" Margin="0,0,0,18">
                    <Border BackgroundColor="#251565C0" StrokeShape="RoundRectangle 8"
                            Stroke="Transparent" Padding="8,6">
                        <Path Data="M3 11 L22 2 L13 21 L11 13 Z" Stroke="White" StrokeThickness="2" Fill="Transparent" WidthRequest="16" HeightRequest="16" VerticalOptions="Center"/>
                    </Border>
                    <VerticalStackLayout Spacing="1" VerticalOptions="Center">
                        <Label x:Name="LblTourTheme" Text="Chọn Tour của bạn"
                               FontSize="16" FontAttributes="Bold" TextColor="#0D2137"/>
                        <Label x:Name="LblTourThemeSub" Text="hành trình ẩm thực độc đáo" FontSize="11" TextColor="#5A7A9A"/>
                    </VerticalStackLayout>
                </HorizontalStackLayout>
                <!-- Tour cards được tạo động từ API -->
                <VerticalStackLayout x:Name="TourCardsContainer" Spacing="14"/>
            </VerticalStackLayout>
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
