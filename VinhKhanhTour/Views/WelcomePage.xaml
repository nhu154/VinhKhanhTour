<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="VinhKhanhTour.Views.WelcomePage"
             NavigationPage.HasNavigationBar="False"
             BackgroundColor="#F8FAFF">

    <ScrollView>
        <VerticalStackLayout Spacing="0">

            <!-- ══ HERO SECTION (PREMIUM REDESIGN) ══ -->
            <Grid HeightRequest="450">
                <!-- Background Gradient -->
                <BoxView>
                    <BoxView.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                            <GradientStop Color="#0D47A1" Offset="0"/>
                            <GradientStop Color="#1565C0" Offset="0.3"/>
                            <GradientStop Color="#1976D2" Offset="0.6"/>
                            <GradientStop Color="#2196F3" Offset="1"/>
                        </LinearGradientBrush>
                    </BoxView.Background>
                </BoxView>

                <!-- Abstract Decorative Shapes -->
                <Ellipse Fill="White" Opacity="0.05" WidthRequest="400" HeightRequest="400"
                         HorizontalOptions="End" VerticalOptions="Start" Margin="0,-180,-150,0"/>
                <Ellipse Fill="White" Opacity="0.08" WidthRequest="220" HeightRequest="220"
                         HorizontalOptions="Start" VerticalOptions="End" Margin="-110,0,0,-80"/>

                <Grid Padding="24,50,24,28">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Top Bar: Location & Lang -->
                    <Grid Grid.Row="0" ColumnDefinitions="*,Auto" VerticalOptions="Start">
                        <Border BackgroundColor="#15FFFFFF" StrokeShape="RoundRectangle 12" Stroke="Transparent"
                                Padding="12,6" HorizontalOptions="Start">
                            <HorizontalStackLayout Spacing="6">
                                <Label x:Name="LblLocation" Text="Quận 4 · TP.HCM" FontSize="12" 
                                       TextColor="White" FontAttributes="Bold" Opacity="0.9"/>
                            </HorizontalStackLayout>
                        </Border>

                        <Border Grid.Column="1" x:Name="LangBtn" 
                                BackgroundColor="White" StrokeShape="RoundRectangle 22" 
                                Stroke="Transparent" Padding="4" HeightRequest="44" WidthRequest="84">
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Tapped="OnLangBtnClicked"/>
                            </Border.GestureRecognizers>
                            <Border.Shadow>
                                <Shadow Brush="Black" Opacity="0.15" Radius="10" Offset="0,4"/>
                            </Border.Shadow>
                            <Grid ColumnDefinitions="*,Auto" Padding="10,0">
                                <Label x:Name="LangFlag" Text="🇻🇳" FontSize="20" VerticalOptions="Center" HorizontalOptions="Center"/>
                                <Label Grid.Column="1" Text="▾" FontSize="12" TextColor="#1565C0" 
                                       FontAttributes="Bold" VerticalOptions="Center" Margin="4,0,0,0"/>
                            </Grid>
                        </Border>
                    </Grid>

                    <!-- Dropdown Ngôn ngữ -->
                    <Border x:Name="LangDropdown" Grid.Row="0" Grid.RowSpan="3"
                            IsVisible="False" BackgroundColor="White"
                            StrokeShape="RoundRectangle 16" Stroke="#E0E0E0"
                            Padding="0" Margin="0,55,0,0"
                            HorizontalOptions="End" VerticalOptions="Start"
                            ZIndex="999" WidthRequest="160">
                        <Border.Shadow>
                            <Shadow Brush="Black" Opacity="0.1" Radius="20" Offset="0,10"/>
                        </Border.Shadow>
                        <VerticalStackLayout x:Name="LangDropdownList" Spacing="0"/>
                    </Border>

                    <!-- Title & Welcome Content -->
                    <VerticalStackLayout Grid.Row="1" VerticalOptions="Center" Spacing="0">
                        <Label Text="VĨNH" FontSize="56" FontAttributes="Bold" TextColor="White" 
                               CharacterSpacing="4" LineHeight="0.9"/>
                        <Label Text="KHÁNH" FontSize="56" FontAttributes="Bold" TextColor="White" 
                               CharacterSpacing="4" Margin="0,-5,0,0"/>

                        <HorizontalStackLayout Spacing="8" Margin="2,8,0,0">
                            <BoxView WidthRequest="24" HeightRequest="3" BackgroundColor="#64B5F6" VerticalOptions="Center"/>
                            <Label x:Name="LblMainSubtitle" Text="CẨM NANG ẨM THỰC" FontSize="14" 
                                   FontAttributes="Bold" TextColor="#BBDEFB" CharacterSpacing="2"/>
                        </HorizontalStackLayout>

                        <Label x:Name="LblWelcome" 
                               Text="Khám phá tinh hoa ẩm thực đường phố Quận 4" 
                               FontSize="16" TextColor="White" Opacity="0.85" 
                               LineHeight="1.5" Margin="2,16,0,0"/>

                        <!-- Stats Bar (Glassmorphism style) -->
                        <Border BackgroundColor="#15FFFFFF" StrokeShape="RoundRectangle 16" 
                                Stroke="#20FFFFFF" Padding="20,15" Margin="0,30,0,0">
                            <HorizontalStackLayout Spacing="25" HorizontalOptions="Center">
                                <VerticalStackLayout HorizontalOptions="Center" Spacing="2">
                                    <Label x:Name="LblStats1Value" Text="11" FontSize="20" FontAttributes="Bold" TextColor="White" HorizontalOptions="Center"/>
                                    <Label x:Name="LblStats1Text" Text="Quán ăn" FontSize="10" TextColor="White" Opacity="0.7" HorizontalOptions="Center"/>
                                </VerticalStackLayout>
                                <BoxView WidthRequest="1" BackgroundColor="White" Opacity="0.2" VerticalOptions="Fill"/>
                                <VerticalStackLayout HorizontalOptions="Center" Spacing="2">
                                    <Label x:Name="LblStats2Value" Text="4" FontSize="20" FontAttributes="Bold" TextColor="White" HorizontalOptions="Center"/>
                                    <Label x:Name="LblStats2Text" Text="Tour" FontSize="10" TextColor="White" Opacity="0.7" HorizontalOptions="Center"/>
                                </VerticalStackLayout>
                                <BoxView WidthRequest="1" BackgroundColor="White" Opacity="0.2" VerticalOptions="Fill"/>
                                <VerticalStackLayout HorizontalOptions="Center" Spacing="2">
                                    <Label x:Name="LblStats3Value" Text="4.8" FontSize="20" FontAttributes="Bold" TextColor="White" HorizontalOptions="Center"/>
                                    <Label x:Name="LblStats3Text" Text="Rating" FontSize="10" TextColor="White" Opacity="0.7" HorizontalOptions="Center"/>
                                </VerticalStackLayout>
                            </HorizontalStackLayout>
                        </Border>
                    </VerticalStackLayout>

                    <!-- CTA Button -->
                    <Border Grid.Row="2" StrokeShape="RoundRectangle 20" Stroke="Transparent" HeightRequest="64">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                <GradientStop Color="#0D47A1" Offset="0"/>
                                <GradientStop Color="#1976D2" Offset="1"/>
                            </LinearGradientBrush>
                        </Border.Background>
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnMapClicked"/>
                        </Border.GestureRecognizers>
                        <Border.Shadow>
                            <Shadow Brush="#0D47A1" Opacity="0.4" Radius="15" Offset="0,6"/>
                        </Border.Shadow>
                        <Grid ColumnDefinitions="*,Auto" Padding="24,0">
                            <HorizontalStackLayout Spacing="12">
                                <Label x:Name="LblCTA" Text="Bắt đầu hành trình" FontSize="18" 
                                       FontAttributes="Bold" TextColor="White" VerticalOptions="Center"/>
                            </HorizontalStackLayout>
                            <Label Grid.Column="1" Text="➜" FontSize="24" TextColor="White" VerticalOptions="Center"/>
                        </Grid>
                    </Border>
                </Grid>
            </Grid>

            <!-- ══ NGÔN NGỮ AUDIO (NHÌN ĐẸP HƠN) ══ -->
            <VerticalStackLayout BackgroundColor="White" Padding="24,24" Spacing="16">
                <HorizontalStackLayout Spacing="12">
                    <VerticalStackLayout VerticalOptions="Center">
                        <Label x:Name="LblNarration" Text="Giọng thuyết minh" FontSize="18" FontAttributes="Bold" TextColor="#1A237E"/>
                        <Label x:Name="LblNarrationSub" Text="Chọn ngôn ngữ audio tour" FontSize="12" TextColor="#78909C"/>
                    </VerticalStackLayout>
                </HorizontalStackLayout>

                <ScrollView Orientation="Horizontal" HorizontalScrollBarVisibility="Never">
                    <HorizontalStackLayout x:Name="LangBtnContainer" Spacing="12" Padding="2,2,24,10"/>
                </ScrollView>
            </VerticalStackLayout>

            <!-- ══ MINI MAP (MODERN BORDER) ══ -->
            <VerticalStackLayout Padding="24,10,24,24" Spacing="16" BackgroundColor="White">
                <HorizontalStackLayout Spacing="12">
                    <VerticalStackLayout VerticalOptions="Center">
                        <Label x:Name="LblChoTour" Text="Bản đồ con phố" FontSize="18" FontAttributes="Bold" TextColor="#1A237E"/>
                        <Label x:Name="LblChoTourSub" Text="Vĩnh Khánh, Phường 8, Quận 4" FontSize="12" TextColor="#78909C"/>
                    </VerticalStackLayout>
                </HorizontalStackLayout>

                <Border StrokeShape="RoundRectangle 24" Stroke="#E0E0E0" HeightRequest="210" 
                        Padding="0" BackgroundColor="#F5F5F5">
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnMapClicked"/>
                    </Border.GestureRecognizers>
                    <Border.Shadow>
                        <Shadow Brush="Black" Opacity="0.08" Radius="15" Offset="0,8"/>
                    </Border.Shadow>
                    <Grid>
                        <WebView x:Name="MiniMapWebView" HorizontalOptions="Fill" VerticalOptions="Fill" InputTransparent="True"/>
                        <!-- Overlay để nhận click -->
                        <BoxView BackgroundColor="Transparent">
                            <BoxView.GestureRecognizers>
                                <TapGestureRecognizer Tapped="OnMapClicked"/>
                            </BoxView.GestureRecognizers>
                        </BoxView>

                        <Border BackgroundColor="#CCFFFFFF" StrokeShape="RoundRectangle 12" 
                                Stroke="Transparent" Padding="12,6"
                                HorizontalOptions="Center" VerticalOptions="End" Margin="0,0,0,16">
                            <Label x:Name="LblTapHint" Text="Nhấn để xem bản đồ lớn" 
                                   FontSize="12" TextColor="#1565C0" FontAttributes="Bold"/>
                        </Border>
                    </Grid>
                </Border>
            </VerticalStackLayout>

            <!-- ══ TICKET BANNER ══ -->
            <VerticalStackLayout x:Name="TicketBannerContainer" Padding="24,16,24,0" Spacing="0"/>

            <!-- ══ TOUR SECTION (CLEANER) ══ -->
            <VerticalStackLayout Padding="24,20,24,40" Spacing="20">
                <HorizontalStackLayout Spacing="12">
                    <VerticalStackLayout VerticalOptions="Center">
                        <Label x:Name="LblTourTheme" Text="Hành trình khám phá" FontSize="18" FontAttributes="Bold" TextColor="#1A237E"/>
                        <Label x:Name="LblTourThemeSub" Text="Gợi ý tour dành cho bạn" FontSize="12" TextColor="#78909C"/>
                    </VerticalStackLayout>
                </HorizontalStackLayout>

                <VerticalStackLayout x:Name="TourCardsContainer" Spacing="18" MinimumHeightRequest="400"/>
            </VerticalStackLayout>
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
