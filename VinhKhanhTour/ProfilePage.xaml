<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="VinhKhanhTour.ProfilePage"
             BackgroundColor="White">

    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="20">

            <!-- Header -->
            <Label Text="👤 Cá Nhân" 
                   FontSize="28" 
                   FontAttributes="Bold" 
                   TextColor="#2C3E50"
                   HorizontalOptions="Center"/>

            <!-- Avatar -->
            <Border StrokeShape="RoundRectangle 60"
                    BackgroundColor="#E8F5E9"
                    WidthRequest="120"
                    HeightRequest="120"
                    HorizontalOptions="Center">
                <Label Text="😊" 
                       FontSize="60"
                       HorizontalOptions="Center"
                       VerticalOptions="Center"/>
            </Border>

            <!-- User Name -->
            <Label Text="Du khách Vĩnh Khánh" 
                   FontSize="20" 
                   FontAttributes="Bold"
                   TextColor="#2C3E50"
                   HorizontalOptions="Center"/>

            <!-- Stats -->
            <Grid ColumnDefinitions="*,*,*" 
                  ColumnSpacing="10"
                  Margin="0,20,0,0">

                <Border Grid.Column="0" 
                        StrokeShape="RoundRectangle 10"
                        BackgroundColor="#FFF3E0"
                        Padding="15">
                    <VerticalStackLayout Spacing="5">
                        <Label Text="0" 
                               FontSize="24" 
                               FontAttributes="Bold"
                               TextColor="#FF6B6B"
                               HorizontalOptions="Center"/>
                        <Label Text="Quán đã ghé" 
                               FontSize="12"
                               TextColor="#666"
                               HorizontalOptions="Center"/>
                    </VerticalStackLayout>
                </Border>

                <Border Grid.Column="1" 
                        StrokeShape="RoundRectangle 10"
                        BackgroundColor="#E3F2FD"
                        Padding="15">
                    <VerticalStackLayout Spacing="5">
                        <Label Text="0" 
                               FontSize="24" 
                               FontAttributes="Bold"
                               TextColor="#FF6B6B"
                               HorizontalOptions="Center"/>
                        <Label Text="Tour hoàn thành" 
                               FontSize="12"
                               TextColor="#666"
                               HorizontalOptions="Center"/>
                    </VerticalStackLayout>
                </Border>

                <Border Grid.Column="2" 
                        StrokeShape="RoundRectangle 10"
                        BackgroundColor="#F3E5F5"
                        Padding="15">
                    <VerticalStackLayout Spacing="5">
                        <Label Text="0" 
                               FontSize="24" 
                               FontAttributes="Bold"
                               TextColor="#FF6B6B"
                               HorizontalOptions="Center"/>
                        <Label Text="Điểm thưởng" 
                               FontSize="12"
                               TextColor="#666"
                               HorizontalOptions="Center"/>
                    </VerticalStackLayout>
                </Border>
            </Grid>

            <!-- Menu Items -->
            <Border StrokeShape="RoundRectangle 10"
                    BackgroundColor="#F5F5F5"
                    Padding="15"
                    Margin="0,20,0,0">
                <VerticalStackLayout Spacing="15">
                    <Label Text="📜 Lịch sử ghé thăm" FontSize="16" TextColor="#2C3E50"/>
                    <BoxView HeightRequest="1" Color="#E0E0E0"/>
                    <Label Text="⭐ Quán yêu thích" FontSize="16" TextColor="#2C3E50"/>
                    <BoxView HeightRequest="1" Color="#E0E0E0"/>
                    <Label Text="🎁 Ưu đãi của tôi" FontSize="16" TextColor="#2C3E50"/>
                    <BoxView HeightRequest="1" Color="#E0E0E0"/>
                    <Label Text="⚙️ Cài đặt" FontSize="16" TextColor="#2C3E50"/>
                </VerticalStackLayout>
            </Border>

            <!-- Footer -->
            <Label Text="🍜 Khám phá Vĩnh Khánh - Thiên đường ẩm thực Quận 4" 
                   FontSize="12"
                   TextColor="#95A5A6"
                   HorizontalOptions="Center"
                   Margin="0,30,0,0"/>

        </VerticalStackLayout>
    </ScrollView>

</ContentPage>