<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="VinhKhanhTour.MainPage"
             BackgroundColor="#F8F9FA">

    <Grid RowDefinitions="Auto,*,Auto">

        <!-- Header -->
        <Border Grid.Row="0"
                BackgroundColor="#FF6B6B"
                StrokeThickness="0"
                Padding="20,30,20,20"
                Margin="0,0,0,10">
            <Border.StrokeShape>
                <RoundRectangle CornerRadius="0,0,30,30"/>
            </Border.StrokeShape>
            <VerticalStackLayout Spacing="5">
                <Label Text="🍜 PHỐ ẨM THỰC VĨNH KHÁNH"
                       FontSize="22"
                       FontAttributes="Bold"
                       TextColor="White"
                       HorizontalTextAlignment="Center"/>
                <Label Text="Khám phá 11 điểm ăn uống nổi tiếng"
                       FontSize="13"
                       TextColor="#FFE5E5"
                       HorizontalTextAlignment="Center"/>
            </VerticalStackLayout>
        </Border>

        <!-- Danh sách nhà hàng -->
        <ScrollView Grid.Row="1">
            <CollectionView x:Name="RestaurantsCollection"
                            SelectionMode="Single"
                            SelectionChanged="OnRestaurantSelected"
                            Margin="15,0">
                <CollectionView.ItemTemplate>
                    <DataTemplate>
                        <Border Margin="0,8"
                                BackgroundColor="White"
                                StrokeThickness="0"
                                Padding="0">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="20"/>
                            </Border.StrokeShape>
                            <Border.Shadow>
                                <Shadow Brush="Black" Opacity="0.1" Radius="10" Offset="0,5"/>
                            </Border.Shadow>

                            <Grid RowDefinitions="140,Auto">

                                <!-- Image area -->
                                <Border Grid.Row="0"
                                        BackgroundColor="#FFE5E5"
                                        StrokeThickness="0">
                                    <Border.StrokeShape>
                                        <RoundRectangle CornerRadius="20,20,0,0"/>
                                    </Border.StrokeShape>
                                    <Grid>
                                        <Label Text="🍜"
                                               FontSize="70"
                                               HorizontalOptions="Center"
                                               VerticalOptions="Center"
                                               Opacity="0.3"/>
                                        <Border BackgroundColor="#FF6B6B"
                                                StrokeThickness="0"
                                                Padding="10,6"
                                                HorizontalOptions="End"
                                                VerticalOptions="Start"
                                                Margin="12">
                                            <Border.StrokeShape>
                                                <RoundRectangle CornerRadius="15"/>
                                            </Border.StrokeShape>
                                            <HorizontalStackLayout Spacing="4">
                                                <Label Text="⭐" FontSize="14"/>
                                                <Label Text="{Binding Rating}"
                                                       FontSize="14"
                                                       FontAttributes="Bold"
                                                       TextColor="White"/>
                                            </HorizontalStackLayout>
                                        </Border>
                                    </Grid>
                                </Border>

                                <!-- Info section -->
                                <VerticalStackLayout Grid.Row="1"
                                                     Padding="15"
                                                     Spacing="8">
                                    <Label Text="{Binding Name}"
                                           FontSize="18"
                                           FontAttributes="Bold"
                                           TextColor="#2C3E50"/>
                                    <Label Text="{Binding Description}"
                                           FontSize="13"
                                           TextColor="#7F8C8D"
                                           LineBreakMode="TailTruncation"
                                           MaxLines="2"/>
                                    <HorizontalStackLayout Spacing="5">
                                        <Label Text="🕐" FontSize="13"/>
                                        <Label Text="{Binding OpenHours}"
                                               FontSize="13"
                                               TextColor="#27AE60"
                                               FontAttributes="Bold"/>
                                    </HorizontalStackLayout>
                                </VerticalStackLayout>

                            </Grid>
                        </Border>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>
        </ScrollView>

        <!-- Bottom: chỉ còn nút Bản Đồ -->
        <Grid Grid.Row="2"
              BackgroundColor="White"
              Padding="15,10"
              ColumnDefinitions="*"
              RowDefinitions="55">

            <Border BackgroundColor="#4ECDC4"
                    StrokeThickness="0">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="15"/>
                </Border.StrokeShape>
                <Border.Shadow>
                    <Shadow Brush="#4ECDC4" Opacity="0.3" Radius="8" Offset="0,3"/>
                </Border.Shadow>
                <Button Text="🗺️ Mở Bản Đồ"
                        BackgroundColor="Transparent"
                        TextColor="White"
                        FontSize="15"
                        FontAttributes="Bold"
                        Clicked="OnMapClicked"/>
            </Border>

        </Grid>

    </Grid>

</ContentPage>
